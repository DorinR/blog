---
import { getCollection, render } from 'astro:content'
import { defaultLocale, moreLocales } from '@/config'
import Layout from '@/layouts/Layout.astro'

export async function getStaticPaths() {
  type PathItem = {
    params: { projects: string }
    props: { lang: string }
  }

  const paths: PathItem[] = []

  paths.push({
    params: { projects: 'projects/' },
    props: { lang: defaultLocale },
  })

  moreLocales.forEach((lang: string) => {
    paths.push({
      params: { projects: `${lang}/projects/` },
      props: { lang },
    })
  })

  return paths
}

const { lang } = Astro.props

const allProjectEntries = await getCollection('projects')
const projectsEntry = allProjectEntries.find(entry => entry.data.lang === lang)
  || allProjectEntries.find(entry => entry.data.lang === '')
const { Content } = projectsEntry ? await render(projectsEntry) : { Content: null }
---

<Layout>
  <div class="uno-decorative-line"></div>
  <div class="heti">
    {Content && <Content />}
  </div>
</Layout>
